# =============================================================================
#  fin_analytics — Environment Variables Template
#  Copy this file to `.env` and fill in the values for your local machine.
#  NEVER commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development          # development | staging | production
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_TIMEZONE=UTC             # IANA timezone string, e.g. America/Sao_Paulo

# -----------------------------------------------------------------------------
# Data Paths  (absolute paths preferred; tildes are expanded automatically)
# If left empty the defaults inside settings.py resolve to ~/fin_analytics/data/*
# -----------------------------------------------------------------------------
DATA_DIR=                    # Root data directory, e.g. /home/cleid/fin_analytics/data
RAW_DIR=                     # Inbox for unprocessed CSVs from Nubank / MyProfit
STAGING_DIR=                 # Intermediate normalised Parquet files
PROCESSED_DIR=               # Final validated Parquet files ready for the warehouse
LOGS_DIR=                    # Application log files

# -----------------------------------------------------------------------------
# DuckDB — local embedded database
# -----------------------------------------------------------------------------
DATABASE_PATH=               # Absolute path to the .duckdb file, e.g. /home/cleid/fin_analytics/db/fin.duckdb
DATABASE_READ_ONLY=false     # Set to true to open the DB in read-only mode (e.g. for reporting)
DATABASE_THREADS=4           # Number of CPU threads DuckDB may use (0 = auto-detect)
DATABASE_MEMORY_LIMIT=1GB    # Maximum RAM DuckDB is allowed to consume

# -----------------------------------------------------------------------------
# Ingestion — Nubank CSV
# -----------------------------------------------------------------------------
NUBANK_CSV_ENCODING=utf-8    # File encoding exported by the Nubank app
NUBANK_DATE_FORMAT=%%d/%%m/%%Y  # strptime format of the date column in the CSV

# -----------------------------------------------------------------------------
# Ingestion — MyProfit CSV
# -----------------------------------------------------------------------------
MYPROFIT_CSV_ENCODING=utf-8
MYPROFIT_DATE_FORMAT=%%Y-%%m-%%d

# -----------------------------------------------------------------------------
# (Optional) Notifications — leave blank to disable
# -----------------------------------------------------------------------------
# NTFY_TOPIC=                # ntfy.sh topic for push notifications on ETL completion
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
