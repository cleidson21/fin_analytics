# =============================================================================
# fin_analytics - Environment Variables Template
# Copy this file to `.env` and fill in the values for your local machine.
# Do not commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Data paths
# Leave blank to use the defaults defined in config/settings.py.
# -----------------------------------------------------------------------------
DATA_DIR=
RAW_DIR=
STAGING_DIR=
PROCESSED_DIR=
DATABASE_DIR=
DATABASE_PATH=
LOGS_DIR=

# -----------------------------------------------------------------------------
# DuckDB local database
# -----------------------------------------------------------------------------
DATABASE_READ_ONLY=false
DATABASE_THREADS=4
DATABASE_MEMORY_LIMIT=1GB

# -----------------------------------------------------------------------------
# Ingestion - Nubank CSV
# -----------------------------------------------------------------------------
NUBANK_CSV_ENCODING=utf-8
NUBANK_DATE_FORMAT=%d/%m/%Y

# -----------------------------------------------------------------------------
# Ingestion - MyProfit CSV
# -----------------------------------------------------------------------------
MYPROFIT_CSV_ENCODING=utf-8
MYPROFIT_DATE_FORMAT=%Y-%m-%d
